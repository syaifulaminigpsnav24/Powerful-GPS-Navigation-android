<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_grey_800"
    tools:context=".MapActivity">

    <com.mapbox.mapboxsdk.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="72dp"
        android:visibility="visible"
        app:maplibre_uiAttribution="true"
        app:maplibre_uiAttributionMarginLeft="2.5dp"
        app:maplibre_uiLogo="false"
        />

    <androidx.fragment.app.FragmentContainerView
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="left|center"
        android:id="@+id/navigation_speed"
        android:name="id.powerfulgpsnavigation.maps.NavigationSpeedometerUI" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginStart="14dp">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/dashboard_menu_map"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/ic_dashboard_menu"
        android:layout_gravity="top|left"
        android:visibility="visible"
        tools:ignore="RtlHardcoded" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/back_to_map_btn"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/baseline_arrow_back_24"
        android:layout_gravity="top|left"
        android:visibility="invisible"
        tools:ignore="RtlHardcoded" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/back_to_searchlist_btn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/baseline_arrow_back_24"
            android:layout_gravity="top|left"
            android:visibility="invisible"
            tools:ignore="RtlHardcoded" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/cancelRouteButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/baseline_arrow_back_ios_new_24"
            android:layout_gravity="top|left"
            android:visibility="invisible"
            tools:ignore="RtlHardcoded" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <EditText
        android:id="@+id/searchLocation"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginEnd="102dp"
        android:layout_marginStart="57dp"
        android:layout_marginTop="14dp"
        android:hint="@string/search_navigate_to"
        android:textAlignment="center"
        android:textColorHint="@color/md_grey_700"
        android:textColor="@color/white"
        android:inputType="textPostalAddress"
        android:importantForAutofill="no" />

    <TextView
        android:id="@+id/PlaceDetailsOnMap"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="14dp"
        android:textAlignment="center"
        android:text="@string/place_information"
        android:textColor="@color/white"
        android:textSize="25sp"
        android:visibility="invisible"
        />

    <LinearLayout
        android:id="@+id/vehicleRouteType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="176dp"
        android:layout_marginEnd="176dp"
        android:visibility="invisible"
        android:layout_marginTop="10dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/drivingRoute"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:background="@drawable/ic_vehicle_car"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/walkingRoute"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:background="@drawable/ic_pedestrian"
            android:backgroundTint="@color/md_grey_700"
            />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/locAddressListInRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_grey_800"
        android:visibility="invisible"
        android:layout_gravity="top"
        android:layout_marginTop="68dp">

        <TextView
            android:id="@+id/emptyLocationAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/type_location_address_here"
            android:textColor="@color/white"
            android:background="@color/md_grey_800"
            android:layout_gravity="center|top"
            android:textAlignment="center"
            android:visibility="visible"
            />

        <ListView
            android:id="@+id/locationAddressList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="60dp"
            android:backgroundTint="@color/md_grey_800"
            android:background="@color/md_grey_800"
            android:visibility="invisible"
            tools:listitem="@layout/location_list_card_view_design"
            app:layout_constraintTop_toTopOf="parent"
            />

    </androidx.cardview.widget.CardView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/searchLocationButton"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:text="@string/search"
        android:textColor="@color/white"
        android:background="@color/md_grey_800"
        android:layout_gravity="top|right"
        tools:ignore="RtlHardcoded" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/locateButton"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_marginBottom="14dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/ic_locate"
        android:layout_gravity="bottom|right"
        android:visibility="visible"
        tools:ignore="RtlHardcoded" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/locationInfo"
        android:layout_width="165dp"
        android:layout_height="match_parent"
        android:layout_marginTop="68dp"
        android:background="@color/md_grey_800"
        android:backgroundTint="@color/md_grey_800"
        android:visibility="invisible"
        android:layout_gravity="bottom">

        <TextView
            android:id="@+id/locationAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="@color/white"
            />

        <TextView
            android:id="@+id/addressCoordinates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="84dp"
            android:textColor="@color/md_grey_500"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/getDirections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="265dp"
            android:backgroundTint="#3F48CC"
            android:text="@string/get_directions"
            android:textColor="@color/white"
            />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/RouteInfo"
        android:layout_width="210dp"
        android:layout_height="match_parent"
        android:layout_marginTop="68dp"
        android:background="@color/md_grey_800"
        android:backgroundTint="@color/md_grey_800"
        android:visibility="invisible"
        android:layout_gravity="bottom">

        <LinearLayout
            android:id="@+id/routeOptions1"
            android:layout_width="125dp"
            android:layout_height="100dp"
            android:layout_marginBottom="186dp"
            android:layout_marginStart="5dp"
            android:layout_gravity="left|center"
            android:orientation="vertical"
            android:background="@color/md_grey_700"
            tools:ignore="RtlHardcoded">

            <TextView
                android:id="@+id/routeDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_marginStart="0dp"
                android:textAlignment="center"
                android:layout_gravity="center"
                />

            <TextView
                android:id="@+id/routeDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_marginStart="0dp"
                android:textAlignment="center"
                android:layout_gravity="center"
                android:text="@string/calculating_route"
                />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/routeOptions2"
            android:layout_width="125dp"
            android:layout_height="100dp"
            android:layout_marginBottom="-40dp"
            android:layout_marginEnd="80dp"
            android:layout_gravity="end|center"
            android:orientation="vertical"
            android:background="@color/md_grey_700">

            <TextView
                android:id="@+id/routeDuration_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_marginStart="0dp"
                android:textAlignment="center"
                android:layout_gravity="center"
                />

            <TextView
                android:id="@+id/routeDistance_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:layout_marginStart="0dp"
                android:textAlignment="center"
                android:layout_gravity="center"
                android:text="@string/calculating_alternative_route"
                />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_navigation_demo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="245dp"
            android:layout_marginBottom="0dp"
            android:layout_marginEnd="0dp"
            android:backgroundTint="#22B14C"
            android:text="@string/demo"
            android:textColor="@color/white"
            android:visibility="invisible"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/startNavigationButton1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:backgroundTint="#3F48CC"
            android:text="@string/start_navigation"
            android:textColor="@color/white"
            android:visibility="invisible"
            android:layout_gravity="bottom"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_navigation_demo_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="250dp"
            android:layout_marginBottom="0dp"
            android:backgroundTint="#22B14C"
            android:text="@string/demo"
            android:textColor="@color/white"
            android:visibility="invisible"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/startNavigationButton2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:backgroundTint="#3F48CC"
            android:text="@string/start_navigation"
            android:textColor="@color/white"
            android:visibility="invisible"
            android:layout_gravity="bottom"
            />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>